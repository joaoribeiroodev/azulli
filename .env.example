# Supabase (criar projeto em supabase.com e copiar do Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Asaas (Fase 5 — pode ficar vazio por enquanto)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Google Gemini (Fase 7 — categorização automática na importação OFX)
# Free tier: gemini-2.5-flash, 1M tokens/dia. Sem essa key, importação
# funciona normalmente, só sem sugestão automática de categoria.
# Pegue em https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=