# Supabase (criar projeto em supabase.com e copiar do Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role — só local/scripts (NUNCA no frontend). Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# App (produto): use.azulli.app.br — em `/` redireciona a login/dashboard (não mostra landing)
# Marketing: azulli.app.br — landing em `/`
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Asaas — sandbox (dev) ou produção (deploy)
# Produção: https://www.asaas.com → Integrações → API
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Produção: ASAAS_BASE_URL=https://api.asaas.com/v3
# Token do webhook (mesmo valor no painel Asaas → Webhooks → autenticação)
ASAAS_WEBHOOK_TOKEN=

# Google Gemini — importação OFX (1 chamada por lote de extrato)
GOOGLE_GENERATIVE_AI_API_KEY=
# Opcional: chave separada só do assistente (quota isolada da importação OFX)
GOOGLE_GENERATIVE_AI_ASSISTANT_KEY=
# Assistente: auto (LLM + fallback automático) | rules (sem LLM, só consultas) | llm (só Gemini)
ASSISTANT_MODE=auto
# Máx. mensagens/dia que tentam LLM no modo auto (protege free tier ~20 req/dia)
ASSISTANT_DAILY_LLM_LIMIT=15

# Resend (Fase 11 — insights semanais por email)
# Free tier: 3.000 emails/mês, 100/dia. Sem essa key, os emails não saem
# (mas o resto do app funciona). Crie em https://resend.com/api-keys
RESEND_API_KEY=
# Email remetente — domínio verificado no Resend (azulli.app.br)
RESEND_FROM_EMAIL="Azulli <oi@azulli.app.br>"

# Secret usado pelo Vercel Cron pra autenticar disparos de jobs.
# Gere: npm run generate:secret (ou openssl rand -hex 32 no Git Bash)
CRON_SECRET=

# --- Growth Platform (WhatsApp IA + Admin + Avisos) ---
# Ver docs/GROWTH_PLATFORM_SETUP.md

# OpenAI — agente de vendas inbound (WhatsApp)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp webhook + provedor (evolution | zapi)
WHATSAPP_PROVIDER=evolution
WHATSAPP_WEBHOOK_TOKEN=

# Evolution API
EVOLUTION_API_URL=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_API_KEY=

# Z-API (alternativa)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

# Subdomínio admin analítico
NEXT_PUBLIC_ADMIN_URL=https://admin.azulli.app.br
# E-mails com acesso admin (comma-separated) — bootstrap
PLATFORM_ADMIN_EMAILS=
# Teste local:
#   npm run test:weekly-insights              → insights (dry run)
#   npm run test:weekly-insights -- --send    → insights (envio real)
#   npm run test:weekly-insights -- --collection --send
#
# Produção (Vercel): vercel.json agenda crons — configure as mesmas vars na Vercel.
# DNS: verifique azulli.app.br no Resend (SPF/DKIM) + DMARC recomendado:
#   _dmarc.azulli.app.br TXT "v=DMARC1; p=none; rua=mailto:oi@azulli.app.br"

# --- Deploy Vercel (checklist) ---
# 1. Conectar repo GitHub → Vercel → Framework Preset: Next.js
# 2. Environment Variables (Production + Preview):
#    - NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - NEXT_PUBLIC_APP_URL=https://use.azulli.app.br
#    - ASAAS_API_KEY, ASAAS_BASE_URL (produção: https://api.asaas.com/v3)
#    - ASAAS_WEBHOOK_TOKEN (mesmo valor no webhook Asaas)
#    - GOOGLE_GENERATIVE_AI_API_KEY, RESEND_API_KEY, RESEND_FROM_EMAIL
#    - CRON_SECRET (Vercel injeta em crons; use o mesmo em Authorization header)
# 3. Domínios na Vercel (mesmo projeto):
#    - use.azulli.app.br → app (NEXT_PUBLIC_APP_URL)
#    - azulli.app.br → site marketing (landing em /)
#    Ambos CNAME → cname.vercel-dns.com
# 4. Supabase: Auth → URL Configuration → Site URL = NEXT_PUBLIC_APP_URL
#    Redirect URLs: https://use.azulli.app.br/auth/callback
# 5. Asaas webhook: https://use.azulli.app.br/api/webhooks/asaas
# 6. Migrations 00021 (onboarding) e 00022 (LGPD delete_my_account) — aplicadas no Supabase
# 7. Pendências de deploy: docs/DEPLOY_PENDENTE.md