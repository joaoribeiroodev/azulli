# Azulli Finder — variáveis (unificado no Next.js + Supabase)

# Usa a mesma DATABASE_URL do .env raiz (Supabase connection string)
# FINDER_JWT_SECRET=...
# FINDER_ADMIN_EMAIL=admin@azulli.local
# FINDER_ADMIN_PASSWORD=...

# Legado Express standalone (opcional — preferir npm run dev na raiz):
# node apps/finder/server.js
