{
  "name": "azulli-finder",
  "version": "1.0.0",
  "description": "Ferramenta interna de prospecção de assinantes para o SaaS Azulli — encontra MEIs e pequenas empresas brasileiras com fit de ICP e ajuda o time comercial a convertê-los em assinantes.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node scripts/migrate.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:rebuild": "docker compose up -d --build",
    "docker:psql": "docker compose exec postgres psql -U postgres -d azulli_finder",
    "docker:tools": "docker compose --profile tools up -d"
  },
  "keywords": [
    "azulli",
    "prospeccao",
    "aquisicao",
    "sdr",
    "crm",
    "leads",
    "icp",
    "meis",
    "pequenas-empresas",
    "google-maps",
    "brasil",
    "saas"
  ],
  "author": "Azulli",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.52.0",
    "pg": "^8.11.5",
    "puppeteer": "^22.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
