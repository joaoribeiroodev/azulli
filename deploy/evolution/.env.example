# Postgres (usado pelo container evolution-postgres)
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=troque-por-senha-forte

# Evolution API — ajuste após expor HTTPS (Cloudflare Tunnel ou domínio público)
SERVER_URL=https://evolution.azulli.app.br
SERVER_PORT=8080

# Mesma chave em EVOLUTION_API_KEY no Azulli (Vercel)
AUTHENTICATION_API_KEY=troque-por-chave-longa-aleatoria

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:troque-por-senha-forte@evolution-postgres:5432/evolution?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_azulli

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution_azulli

DEL_INSTANCE=false
LOG_LEVEL=ERROR,WARN,INFO
LOG_BAILEYS=error
CORS_ORIGIN=*
